[Desktop Entry]
Version=1.0
Name=Fenrir Browser
GenericName=Web Browser
Comment=Fast, private web browser for FenrirOS
Exec=firefox %u
Icon=firefox
Terminal=false
Type=Application
Categories=Network;WebBrowser;
