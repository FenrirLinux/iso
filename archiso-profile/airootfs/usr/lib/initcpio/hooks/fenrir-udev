#!/usr/bin/ash
# FenrirOS custom udev hook for mkinitcpio
# Uses Artix eudev - udevd at /usr/bin/udevd

run_earlyhook() {
    /usr/bin/udevd --daemon --resolve-names=never
}

run_hook() {
    msg ":: Triggering uevents..."
    udevadm trigger --action=add --type=subsystems
    udevadm trigger --action=add --type=devices
    udevadm settle

    # Wait for archiso device to appear (USB or CD-ROM)
    local i=0
    while [ $i -lt 60 ]; do
        # Check for USB device with our label
        if blkid | grep -q "FENRIR_202604"; then
            msg ":: FenrirOS device found"
            break
        fi
        # Also check for sr0 (CD-ROM) or sda/sdb (USB)
        if [ -b /dev/sr0 ] || [ -b /dev/sda ] || [ -b /dev/sdb ]; then
            udevadm settle
            break
        fi
        sleep 1
        i=$((i + 1))
    done
}

run_cleanuphook() {
    udevadm control --exit
    udevadm info --cleanup-db
}
